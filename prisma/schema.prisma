generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CompanyRole {
  ADMIN
  ACCOUNTANT
}

model User {
  id           String       @id @default(uuid())
  fullName     String
  username     String       @unique
  passwordHash String
  companyRole  CompanyRole?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
}
